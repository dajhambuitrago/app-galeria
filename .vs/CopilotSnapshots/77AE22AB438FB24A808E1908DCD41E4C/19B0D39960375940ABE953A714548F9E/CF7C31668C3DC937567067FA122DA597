using AutoMapper;
using Backend.Application.Abstractions.Repositories;
using Backend.Application.DTOs;
using Backend.Domain.Common;
using Backend.Domain.Entities;
using Backend.Domain.Enums;
using MediatR;

namespace Backend.Application.Features.Slideshow.Queries;

public record GetSlideshowQuery(string? UserId, bool OnlyFavorites, string? Category, MediaType? Type, SlideshowOrder Order) : IRequest<Result<SlideshowDto>>;

public class GetSlideshowQueryHandler(
    ISettingRepository settingRepository,
    IMediaRepository mediaRepository,
    IFavoriteRepository favoriteRepository,
    IMapper mapper) : IRequestHandler<GetSlideshowQuery, Result<SlideshowDto>>
{
    public async Task<Result<SlideshowDto>> Handle(GetSlideshowQuery request, CancellationToken cancellationToken)
    {
        var settings = await settingRepository.GetAsync(cancellationToken);
        if (settings is null)
        {
            return Result<SlideshowDto>.Failure("Configuración no encontrada.");
        }

        List<MediaItem> items;

        if (request.OnlyFavorites)
        {
            if (string.IsNullOrWhiteSpace(request.UserId))
            {
                return Result<SlideshowDto>.Failure("Usuario inválido.");
            }

            var favorites = await favoriteRepository.GetByUserIdAsync(request.UserId, cancellationToken);
            items = favorites
                .Where(x => x.MediaItem is not null)
                .Select(x => x.MediaItem!)
                .ToList();

            if (!string.IsNullOrWhiteSpace(request.Category))
            {
                var normalized = request.Category.Trim().ToLower();
                items = items.Where(x => x.Category != null && x.Category.Name.ToLower() == normalized).ToList();
            }

            if (request.Type.HasValue)
            {
                items = items.Where(x => x.Type == request.Type.Value).ToList();
            }
        }
        else
        {
            items = await mediaRepository.FilterAsync(request.Category, request.Type, cancellationToken);
        }

        items = request.Order switch
        {
            SlideshowOrder.TitleDesc => items.OrderByDescending(x => x.Title).ToList(),
            SlideshowOrder.Random => items.OrderBy(_ => Guid.NewGuid()).ToList(),
            _ => items.OrderBy(x => x.Title).ToList()
        };

        var media = mapper.Map<List<MediaDto>>(items);
        var result = new SlideshowDto(
            settings.SlideshowDurationSeconds,
            media.Count,
            request.Order.ToString(),
            media);
        return Result<SlideshowDto>.Success(result);
    }
}
