using Backend.Application.Features.Settings.Commands;
using Backend.Application.Features.Settings.Queries;
using Backend.WebAPI.Extensions;
using MediatR;
using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;

namespace Backend.WebAPI.Controllers;

[ApiController]
[Route("api/settings")]
public class SettingsController(IMediator mediator) : ControllerBase
{
    [HttpGet("slideshow-duration")]
    [Authorize(Roles = "User,Admin")]
    public async Task<IActionResult> GetSlideshowDuration(CancellationToken cancellationToken)
    {
        var result = await mediator.Send(new GetSlideshowDurationQuery(), cancellationToken);
        return this.ToActionResult(result);
    }

    [HttpPut("slideshow-duration")]
    [Authorize(Roles = "Admin")]
    public async Task<IActionResult> UpdateSlideshowDuration(UpdateSlideshowDurationCommand command, CancellationToken cancellationToken)
    {
        var result = await mediator.Send(command, cancellationToken);
        return this.ToActionResult(result);
    }
}
