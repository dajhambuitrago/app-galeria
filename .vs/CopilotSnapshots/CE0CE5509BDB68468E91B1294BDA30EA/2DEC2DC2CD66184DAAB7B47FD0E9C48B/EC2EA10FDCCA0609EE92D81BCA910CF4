  display: grid;
  grid-template-columns: repeat(12, minmax(0, 1fr));
  gap: 1rem;
}

.pin-card {
  grid-column: span 3;
  cursor: pointer;
  border-radius: 14px;
  overflow: hidden;
  transition: transform 0.18s ease, box-shadow 0.18s ease;
}

.pin-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 14px 28px rgba(0, 0, 0, 0.12) !important;
}

.pin-media {
  background: #eef1f5;
}

.tile-standard .pin-media {
  aspect-ratio: 4 / 5;
}

.tile-tall .pin-media {
  aspect-ratio: 4 / 6;
}

.tile-large {
  grid-column: span 6;
}

.tile-large .pin-media {
  aspect-ratio: 16 / 9;
}

.pin-media img,
.pin-media video {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

.fav-btn {
  width: 2rem;
  height: 2rem;
  padding: 0;
  border-radius: 999px;
}

.fade-slide-enter-active,
.fade-slide-leave-active {
  transition: opacity 0.22s ease, transform 0.22s ease;
}

.fade-slide-enter-from,
.fade-slide-leave-to {
  opacity: 0;
