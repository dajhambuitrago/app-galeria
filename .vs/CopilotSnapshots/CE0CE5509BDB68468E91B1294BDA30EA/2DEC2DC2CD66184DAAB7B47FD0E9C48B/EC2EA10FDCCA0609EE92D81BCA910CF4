<script setup lang="ts">
import { computed, onBeforeUnmount, onMounted, ref } from 'vue'
import {
  addFavorite,
  getCategories,
  getFavorites,
  getMedia,
  getSlideshow,
  login,
  register,
  removeFavorite,
} from '@/services/api'
import type { CategoryDto, MediaDto, SlideshowDto } from '@/types/api'
import MediaLightbox from '@/components/MediaLightbox.vue'
import { useSlideshowPlayer } from '@/composables/useSlideshowPlayer'

type AuthMode = 'login' | 'register'

const authMode = ref<AuthMode>('login')
const email = ref('admin@appgaleria.local')
const password = ref('Admin123!')
const confirmPassword = ref('')
const token = ref(localStorage.getItem('appgaleria_token') ?? '')
const currentUserEmail = ref(localStorage.getItem('appgaleria_user_email') ?? '')
const selectedCategory = ref('')
const searchQuery = ref('')

const categories = ref<CategoryDto[]>([])
const mediaItems = ref<MediaDto[]>([])
const slideshow = ref<SlideshowDto | null>(null)
const error = ref('')
const loading = ref(false)
const favoriteIds = ref<Set<string>>(new Set())
const favoritesEnabled = ref(true)

const isAuthenticated = computed(() => !!token.value)
const slideshowDurationSeconds = computed(() => slideshow.value?.slideshowDurationSeconds ?? 8)
const isRegisterMode = computed(() => authMode.value === 'register')

const visibleItems = computed(() => {
  const q = searchQuery.value.trim().toLowerCase()
  if (!q) return mediaItems.value
  return mediaItems.value.filter(
    (x) => x.title.toLowerCase().includes(q) || x.categoryName.toLowerCase().includes(q),
  )
})

const {
  activeItem,
  isPlaying,
  openItem,
  openFirst,
  closeViewer,
  nextItem,
  prevItem,
  togglePlay,
  syncWithMediaItems,
  dispose,
} = useSlideshowPlayer(visibleItems, slideshowDurationSeconds)

function switchAuthMode(mode: AuthMode) {
  authMode.value = mode
  error.value = ''
  confirmPassword.value = ''
}

function selectCategory(name: string) {
  selectedCategory.value = name
  void loadMedia()
}

function startPresentation() {
  if (visibleItems.value.length === 0) return
  openFirst()
  if (!isPlaying.value) {
    togglePlay()
  }
}

async function handleAuthSubmit() {
  if (isRegisterMode.value) {
    await handleRegister()
    return
  }

  await handleLogin()
}

const favoritesStorageKey = computed(() =>
  currentUserEmail.value
    ? `appgaleria_favorites_${currentUserEmail.value.toLowerCase()}`
    : 'appgaleria_favorites',
)

function persistFavoritesToLocalStorage() {
  localStorage.setItem(favoritesStorageKey.value, JSON.stringify(Array.from(favoriteIds.value)))
}

function restoreFavoritesFromLocalStorage() {
  const raw = localStorage.getItem(favoritesStorageKey.value)
  if (!raw) {
    favoriteIds.value = new Set()
    return
  }

  try {
    const parsed = JSON.parse(raw) as string[]
    favoriteIds.value = new Set(parsed)
  } catch {
    favoriteIds.value = new Set()
  }
}

async function handleLogin() {
  try {
    loading.value = true
    error.value = ''
    const response = await login(email.value, password.value)
    token.value = response.token
    currentUserEmail.value = response.email
    localStorage.setItem('appgaleria_token', response.token)
    localStorage.setItem('appgaleria_user_email', response.email)
    await loadInitialData()
  } catch (e) {
    error.value = `No se pudo iniciar sesión: ${String(e)}`
  } finally {
    loading.value = false
  }
}

async function handleRegister() {
  if (password.value !== confirmPassword.value) {
    error.value = 'Las contraseñas no coinciden.'
    return
  }

  try {
    loading.value = true
    error.value = ''
    const response = await register(email.value, password.value)
    token.value = response.token
    currentUserEmail.value = response.email
    localStorage.setItem('appgaleria_token', response.token)
    localStorage.setItem('appgaleria_user_email', response.email)
    await loadInitialData()
  } catch (e) {
    error.value = `No se pudo registrar: ${String(e)}`
  } finally {
    loading.value = false
  }
}

function logout() {
  closeViewer()
  token.value = ''
  currentUserEmail.value = ''
  localStorage.removeItem('appgaleria_token')
  localStorage.removeItem('appgaleria_user_email')
  categories.value = []
  mediaItems.value = []
  slideshow.value = null
  searchQuery.value = ''
  favoriteIds.value = new Set()
  favoritesEnabled.value = true
}

function setFavoriteState(mediaId: string, value: boolean) {
  const next = new Set(favoriteIds.value)
  if (value) {
    next.add(mediaId)
  } else {
    next.delete(mediaId)
  }
  favoriteIds.value = next
  persistFavoritesToLocalStorage()
}

function isFavorite(mediaId: string) {
  return favoriteIds.value.has(mediaId)
}

async function toggleFavorite(mediaId: string) {
  if (!token.value || !favoritesEnabled.value) return

  const current = isFavorite(mediaId)
  setFavoriteState(mediaId, !current)

  try {
    if (current) {
      await removeFavorite(token.value, mediaId)
    } else {
      await addFavorite(token.value, mediaId)
    }
  } catch (e) {
    setFavoriteState(mediaId, current)
    error.value = `No se pudo actualizar favorito: ${String(e)}`
  }
}

async function loadFavorites() {
  if (!token.value) return

  restoreFavoritesFromLocalStorage()

  try {
    const favorites = await getFavorites(token.value)
    favoriteIds.value = new Set(favorites.map((x) => x.mediaItemId))
    favoritesEnabled.value = true
    persistFavoritesToLocalStorage()
  } catch {
    favoritesEnabled.value = false
  }
}

async function loadInitialData() {
  if (!token.value) return

  try {
    error.value = ''
    const [categoryData, slideshowData] = await Promise.all([
      getCategories(token.value),
      getSlideshow(token.value),
    ])

    categories.value = categoryData
    slideshow.value = slideshowData

    await Promise.all([loadMedia(), loadFavorites()])
  } catch (e) {
    error.value = `No se pudo cargar la galería: ${String(e)}`
    throw e
  }
}

async function loadMedia() {
  if (!token.value) return

  try {
    error.value = ''
    mediaItems.value = await getMedia(token.value, selectedCategory.value || undefined)
    syncWithMediaItems()
  } catch (e) {
    mediaItems.value = []
    error.value = `No se pudo cargar el contenido multimedia: ${String(e)}`
  }
}

function getCollageClass(index: number) {
  const pattern = index % 10

  if (pattern === 0 || pattern === 6) return 'tile-large'
  if (pattern === 3 || pattern === 8) return 'tile-tall'
  return 'tile-standard'
}

onMounted(async () => {
  if (token.value) {
    try {
      await loadInitialData()
    } catch {
      logout()
    }
  }
})

onBeforeUnmount(() => {
  dispose()
})
</script>

<template>
  <main class="container-fluid py-3 py-md-4 app-shell">
    <header class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-3 mb-md-4">
      <div>
        <h1 class="h3 mb-1 fw-bold">appGaleria</h1>
        <p class="text-secondary mb-0">Descubre contenido visual estilo Pinterest.</p>
      </div>
      <button v-if="isAuthenticated" class="btn btn-outline-secondary" @click="logout">
        <i class="bi bi-box-arrow-right me-1"></i>Cerrar sesión
      </button>
    </header>

    <Transition name="fade-slide" mode="out-in">
      <section v-if="!isAuthenticated" key="login" class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-5">
          <div class="card shadow-sm border-0 login-card">
            <div class="card-body p-4">
              <div class="btn-group w-100 mb-3" role="group" aria-label="Modo de autenticación">
                <button
                  type="button"
                  class="btn"
                  :class="authMode === 'login' ? 'btn-primary' : 'btn-outline-primary'"
                  @click="switchAuthMode('login')"
                >
                  Iniciar sesión
                </button>
                <button
                  type="button"
                  class="btn"
                  :class="authMode === 'register' ? 'btn-primary' : 'btn-outline-primary'"
                  @click="switchAuthMode('register')"
                >
                  Registrarme
                </button>
              </div>

              <h2 class="h4 mb-2">{{ isRegisterMode ? 'Crear cuenta' : 'Bienvenido de nuevo' }}</h2>
              <p class="text-secondary mb-3">
                {{
                  isRegisterMode
                    ? 'Regístrate para guardar tus favoritos y personalizar tu galería.'
                    : 'Accede para explorar, guardar favoritos y usar el modo presentación.'
                }}
              </p>

              <form class="d-grid gap-3" @submit.prevent="handleAuthSubmit">
                <div>
                  <label class="form-label">Correo</label>
                  <input v-model="email" class="form-control" type="email" placeholder="tu-correo@ejemplo.com" required />
                </div>
                <div>
                  <label class="form-label">Contraseña</label>
                  <input v-model="password" class="form-control" type="password" placeholder="••••••••" required />
                </div>
                <div v-if="isRegisterMode">
                  <label class="form-label">Confirmar contraseña</label>
                  <input v-model="confirmPassword" class="form-control" type="password" placeholder="••••••••" required />
                </div>

                <button class="btn btn-primary btn-lg" :disabled="loading" type="submit">
                  <span v-if="loading" class="spinner-border spinner-border-sm me-2" role="status"></span>
                  {{ loading ? (isRegisterMode ? 'Registrando...' : 'Ingresando...') : (isRegisterMode ? 'Crear cuenta' : 'Entrar') }}
                </button>
              </form>
            </div>
          </div>
        </div>
      </section>

      <section v-else key="gallery">
        <div class="card border-0 shadow-sm mb-3">
          <div class="card-body d-flex flex-column flex-lg-row gap-3 justify-content-between align-items-lg-center">
            <div>
              <h2 class="h5 mb-1">Galería</h2>
              <small class="text-secondary">{{ visibleItems.length }} elementos visibles</small>
            </div>

            <div class="d-flex flex-column flex-md-row gap-2 w-100 w-lg-auto">
              <input
                v-model="searchQuery"
                class="form-control"
                type="search"
                placeholder="Buscar por título o categoría"
              />
              <button class="btn btn-primary" :disabled="visibleItems.length === 0" @click="startPresentation">
                <i class="bi bi-play-circle me-1"></i>Iniciar presentación
              </button>
            </div>
          </div>
        </div>

        <div class="d-flex flex-wrap gap-2 mb-3 category-pills">
          <button
            class="btn btn-sm"
            :class="selectedCategory === '' ? 'btn-dark' : 'btn-outline-dark'"
            @click="selectCategory('')"
          >
            Todas
          </button>
          <button
            v-for="c in categories"
            :key="c.id"
            class="btn btn-sm"
            :class="selectedCategory === c.name ? 'btn-dark' : 'btn-outline-dark'"
            @click="selectCategory(c.name)"
          >
            {{ c.name }}
          </button>
        </div>

        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
          <span v-if="slideshow" class="badge text-bg-light border">
            <i class="bi bi-sliders me-1"></i>{{ slideshow.slideshowDurationSeconds }}s · {{ slideshow.totalItems }} · {{ slideshow.effectiveOrder }}
          </span>
          <span v-if="!favoritesEnabled" class="badge text-bg-warning">
            Favoritos habilitados solo para cuentas con rol User
          </span>
        </div>

        <p v-if="visibleItems.length === 0" class="text-secondary">No hay contenido multimedia que coincida con tu búsqueda.</p>

        <TransitionGroup name="card-fade" tag="div" class="collage-grid">
          <article
            v-for="(item, index) in visibleItems"
            :key="item.id"
            class="pin-card card border-0 shadow-sm"
            :class="getCollageClass(index)"
            @click="openItem(index)"
          >
            <div class="pin-media">
              <img v-if="item.type === 1" :src="item.url" :alt="item.title" loading="lazy" />
              <video v-else :src="item.url" controls preload="metadata" />
            </div>

            <div class="card-body p-3">
              <div class="d-flex justify-content-between gap-2 align-items-start mb-1">
                <h3 class="h6 mb-0 fw-semibold text-truncate" :title="item.title">{{ item.title }}</h3>
                <button
                  v-if="favoritesEnabled"
                  class="btn btn-sm fav-btn"
                  :class="isFavorite(item.id) ? 'btn-danger' : 'btn-outline-danger'"
                  :aria-label="isFavorite(item.id) ? 'Quitar de favoritos' : 'Agregar a favoritos'"
                  @click.stop="toggleFavorite(item.id)"
                >
                  <i class="bi" :class="isFavorite(item.id) ? 'bi-heart-fill' : 'bi-heart'"></i>
                </button>
              </div>

              <p class="small text-secondary mb-2">{{ item.categoryName }} · {{ item.type === 1 ? 'Imagen' : 'Video' }}</p>
              <a :href="item.url" target="_blank" rel="noreferrer" class="small" @click.stop>Ver original</a>
            </div>
          </article>
        </TransitionGroup>
      </section>
    </Transition>

    <Transition name="fade-slide">
      <div v-if="error" class="alert alert-danger mt-3 mb-0">{{ error }}</div>
    </Transition>

    <MediaLightbox
      :item="activeItem"
      :is-playing="isPlaying"
      @close="closeViewer"
      @next="nextItem"
      @prev="prevItem"
      @toggle-play="togglePlay"
    />
  </main>
</template>

<style scoped>
