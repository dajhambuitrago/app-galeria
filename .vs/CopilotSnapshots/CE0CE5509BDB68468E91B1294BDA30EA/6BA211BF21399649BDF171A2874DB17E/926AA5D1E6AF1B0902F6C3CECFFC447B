<script setup lang="ts">
import { computed, onMounted, ref } from 'vue'
import {
  createCategory,
  createMedia,
  deleteCategory,
  deleteMedia,
  getCategories,
  getMedia,
  updateCategory,
  updateMedia,
  uploadMediaFile,
} from '@/services/api'
import type { CategoryDto, MediaDto } from '@/types/api'

const token = ref(localStorage.getItem('appgaleria_token') ?? '')
const currentUserRoles = ref<string[]>(
  JSON.parse(localStorage.getItem('appgaleria_user_roles') ?? '[]') as string[],
)
const apiBaseUrl = import.meta.env.VITE_API_BASE_URL ?? 'http://localhost:5241'

const adminTab = ref<'media' | 'categories'>('media')
const categories = ref<CategoryDto[]>([])
const mediaItems = ref<MediaDto[]>([])
const error = ref('')
const loading = ref(false)

const newCategoryName = ref('')
const editingCategoryId = ref<string | null>(null)
const editingCategoryName = ref('')

const mediaForm = ref({
  id: '',
  title: '',
  url: '',
  type: 1,
  categoryId: '',
})
const mediaPreviewUrl = ref('')

const isAdmin = computed(() => currentUserRoles.value.includes('Admin'))

function resolveMediaUrl(url: string) {
  if (url.startsWith('http') || url.startsWith('data:')) {
    return url
  }

  return `${apiBaseUrl}${url}`
}

function switchAdminTab(tab: 'media' | 'categories') {
  adminTab.value = tab
}

function resetMediaForm() {
  if (mediaPreviewUrl.value && mediaPreviewUrl.value.startsWith('blob:')) {
    URL.revokeObjectURL(mediaPreviewUrl.value)
  }

  mediaPreviewUrl.value = ''
  mediaForm.value = {
    id: '',
    title: '',
    url: '',
    type: 1,
    categoryId: categories.value[0]?.id ?? '',
  }
}

function selectMediaForEdit(item: MediaDto) {
  if (mediaPreviewUrl.value && mediaPreviewUrl.value.startsWith('blob:')) {
    URL.revokeObjectURL(mediaPreviewUrl.value)
  }

  mediaPreviewUrl.value = resolveMediaUrl(item.url)
  mediaForm.value = {
    id: item.id,
    title: item.title,
    url: item.url,
    type: item.type,
    categoryId: categories.value.find((cat) => cat.name === item.categoryName)?.id ?? '',
  }
}

async function handleMediaFileChange(event: Event) {
  const input = event.target as HTMLInputElement
  const file = input.files?.[0]
  if (!file || !token.value) return

  if (mediaPreviewUrl.value && mediaPreviewUrl.value.startsWith('blob:')) {
    URL.revokeObjectURL(mediaPreviewUrl.value)
  }

  mediaPreviewUrl.value = URL.createObjectURL(file)
  mediaForm.value.type = file.type.startsWith('video/') ? 2 : 1

  try {
    const uploadedUrl = await uploadMediaFile(token.value, file)
    mediaForm.value.url = uploadedUrl
  } catch (e) {
    error.value = `No se pudo subir el archivo: ${String(e)}`
  }
}

async function saveMedia() {
  if (!token.value) return

  const payload = {
    title: mediaForm.value.title.trim(),
    url: mediaForm.value.url.trim(),
    type: Number(mediaForm.value.type),
    categoryId: mediaForm.value.categoryId,
    id: mediaForm.value.id,
  }

  if (!payload.title || !payload.url || !payload.categoryId) {
    error.value = 'Completa título, archivo y categoría.'
    return
  }

  try {
    error.value = ''
    if (payload.id) {
      await updateMedia(token.value, payload)
    } else {
      await createMedia(token.value, payload)
    }

    resetMediaForm()
    await loadMedia()
  } catch (e) {
    error.value = `No se pudo guardar el media: ${String(e)}`
  }
}

async function removeMediaItem(id: string) {
  if (!token.value) return

  try {
    error.value = ''
    await deleteMedia(token.value, id)
    await loadMedia()
  } catch (e) {
    error.value = `No se pudo eliminar el media: ${String(e)}`
  }
}

function selectCategoryForEdit(category: CategoryDto) {
  editingCategoryId.value = category.id
  editingCategoryName.value = category.name
}

async function saveCategory() {
  if (!token.value) return

  const name = (editingCategoryId.value ? editingCategoryName.value : newCategoryName.value).trim()
  if (!name) {
    error.value = 'Ingresa el nombre de la categoría.'
    return
  }

  try {
    error.value = ''
    if (editingCategoryId.value) {
      await updateCategory(token.value, editingCategoryId.value, name)
    } else {
      await createCategory(token.value, name)
    }

    newCategoryName.value = ''
    editingCategoryId.value = null
    editingCategoryName.value = ''
    await loadCategories()
  } catch (e) {
    error.value = `No se pudo guardar la categoría: ${String(e)}`
  }
}

async function removeCategoryItem(id: string) {
  if (!token.value) return

  try {
    error.value = ''
    await deleteCategory(token.value, id)
    await loadCategories()
  } catch (e) {
    error.value = `No se pudo eliminar la categoría: ${String(e)}`
  }
}

async function loadCategories() {
  if (!token.value) return

  categories.value = await getCategories(token.value)
  if (!mediaForm.value.categoryId && categories.value.length > 0) {
    mediaForm.value.categoryId = categories.value[0]?.id ?? ''
  }
}

async function loadMedia() {
  if (!token.value) return

  mediaItems.value = await getMedia(token.value)
}

onMounted(async () => {
  if (!token.value || !isAdmin.value) return

  await Promise.all([loadCategories(), loadMedia()])
})
</script>

<template>
  <main class="container-fluid py-3 py-md-4 admin-shell">
    <header class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-3">
      <div>
        <h1 class="h4 fw-bold mb-1">Panel Admin</h1>
        <p class="text-secondary mb-0">Administra media y categorías.</p>
      </div>
      <RouterLink class="btn btn-outline-secondary" to="/">
        <i class="bi bi-arrow-left me-1"></i>Volver a galería
      </RouterLink>
    </header>

    <div v-if="!token" class="alert alert-warning">Inicia sesión para administrar contenido.</div>
    <div v-else-if="!isAdmin" class="alert alert-danger">Acceso solo para administradores.</div>

    <div v-else class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="btn-group mb-3" role="group" aria-label="Admin">
          <button
            class="btn"
            :class="adminTab === 'media' ? 'btn-primary' : 'btn-outline-primary'"
            @click="switchAdminTab('media')"
          >
            <i class="bi bi-image me-1"></i>Media
          </button>
          <button
            class="btn"
            :class="adminTab === 'categories' ? 'btn-primary' : 'btn-outline-primary'"
            @click="switchAdminTab('categories')"
          >
            <i class="bi bi-tags me-1"></i>Categorías
          </button>
        </div>

        <div v-if="adminTab === 'media'" class="row g-3">
          <div class="col-12 col-lg-5">
            <h3 class="h6">{{ mediaForm.id ? 'Editar media' : 'Nuevo media' }}</h3>
            <div class="vstack gap-2">
              <input v-model="mediaForm.title" class="form-control" placeholder="Título" />
              <div class="vstack gap-1">
                <label class="form-label mb-0">Archivo</label>
                <input class="form-control" type="file" accept="image/*,video/*" @change="handleMediaFileChange" />
                <small class="text-secondary">Selecciona imagen o video para guardar localmente.</small>
              </div>
              <select v-model="mediaForm.type" class="form-select">
                <option :value="1">Imagen</option>
                <option :value="2">Video</option>
              </select>
              <select v-model="mediaForm.categoryId" class="form-select">
                <option disabled value="">Selecciona categoría</option>
                <option v-for="cat in categories" :key="cat.id" :value="cat.id">{{ cat.name }}</option>
              </select>
              <div class="d-flex gap-2">
                <button class="btn btn-success" :disabled="loading" @click="saveMedia">
                  {{ mediaForm.id ? 'Actualizar' : 'Guardar' }}
                </button>
                <button class="btn btn-outline-secondary" @click="resetMediaForm">Limpiar</button>
              </div>
              <div v-if="mediaPreviewUrl" class="admin-preview rounded border">
                <img v-if="mediaForm.type === 1" :src="mediaPreviewUrl" alt="preview" />
                <video v-else :src="mediaPreviewUrl" controls />
              </div>
            </div>
          </div>

          <div class="col-12 col-lg-7">
            <h3 class="h6">Listado</h3>
            <div class="admin-media-grid">
              <div v-for="item in mediaItems" :key="item.id" class="admin-media-card">
                <div class="admin-media-thumb">
                  <img v-if="item.type === 1" :src="resolveMediaUrl(item.url)" :alt="item.title" />
                  <div v-else class="video-poster">
                    <i class="bi bi-play-circle-fill"></i>
                    <span>Video</span>
                  </div>
                </div>
                <div class="admin-media-body">
                  <h4 class="h6 mb-1 text-truncate" :title="item.title">{{ item.title }}</h4>
                  <small class="text-secondary">{{ item.categoryName }}</small>
                  <div class="d-flex gap-2 mt-2">
                    <button class="btn btn-sm btn-outline-primary" @click="selectMediaForEdit(item)">
                      Editar
                    </button>
                    <button class="btn btn-sm btn-outline-danger" @click="removeMediaItem(item.id)">
                      Eliminar
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div v-else class="row g-3">
          <div class="col-12 col-lg-5">
            <h3 class="h6">{{ editingCategoryId ? 'Editar categoría' : 'Nueva categoría' }}</h3>
            <div class="vstack gap-2">
              <input
                v-if="editingCategoryId"
                v-model="editingCategoryName"
                class="form-control"
                placeholder="Nombre de la categoría"
              />
              <input
                v-else
                v-model="newCategoryName"
                class="form-control"
                placeholder="Nombre de la categoría"
              />
              <div class="d-flex gap-2">
                <button class="btn btn-success" @click="saveCategory">
                  {{ editingCategoryId ? 'Actualizar' : 'Guardar' }}
                </button>
                <button
                  v-if="editingCategoryId"
                  class="btn btn-outline-secondary"
                  @click="() => { editingCategoryId = null; editingCategoryName = '' }"
                >
                  Cancelar
                </button>
              </div>
            </div>
          </div>

          <div class="col-12 col-lg-7">
            <h3 class="h6">Listado</h3>
            <div class="admin-category-grid">
              <div v-for="category in categories" :key="category.id" class="admin-category-card">
                <div>
                  <strong>{{ category.name }}</strong>
                </div>
                <div class="admin-category-actions">
                  <button class="btn btn-sm btn-outline-primary" @click="selectCategoryForEdit(category)">
                    Editar
                  </button>
                  <button class="btn btn-sm btn-outline-danger" @click="removeCategoryItem(category.id)">
                    Eliminar
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div v-if="error" class="alert alert-danger mt-3 mb-0">{{ error }}</div>
  </main>
</template>

