<script setup lang="ts">
import { computed, ref, watch } from 'vue'
import type { MediaDto } from '@/types/api'

const props = defineProps<{
  item: MediaDto | null
  isPlaying: boolean
}>()

const emit = defineEmits<{
  close: []
  next: []
  prev: []
  togglePlay: []
}>()

const zoomScale = ref(1)
const zoomX = ref(0)
const zoomY = ref(0)
const isDragging = ref(false)
const dragStartX = ref(0)
const dragStartY = ref(0)

const zoomStyle = computed(() => ({
  transform: `translate(${zoomX.value}px, ${zoomY.value}px) scale(${zoomScale.value})`,
}))

function resetZoom() {
  zoomScale.value = 1
  zoomX.value = 0
  zoomY.value = 0
}

function zoomIn() {
  if (!props.item || props.item.type !== 1) return
  zoomScale.value = Math.min(3, zoomScale.value + 0.2)
}

function zoomOut() {
  if (!props.item || props.item.type !== 1) return
  const next = Math.max(1, zoomScale.value - 0.2)
  zoomScale.value = next
  if (next === 1) {
    zoomX.value = 0
    zoomY.value = 0
  }
}

function handlePointerDown(event: PointerEvent) {
  if (!props.item || props.item.type !== 1 || zoomScale.value === 1) return
  isDragging.value = true
  dragStartX.value = event.clientX - zoomX.value
  dragStartY.value = event.clientY - zoomY.value
}

function handlePointerMove(event: PointerEvent) {
  if (!isDragging.value) return
  zoomX.value = event.clientX - dragStartX.value
  zoomY.value = event.clientY - dragStartY.value
}

function handlePointerUp() {
  isDragging.value = false
}

watch(
  () => props.item?.id,
  () => resetZoom(),
)
</script>

<template>
  <Transition name="lightbox">
    <div v-if="item" class="overlay" @click.self="emit('close')">
      <div class="dialog card border-0 shadow-lg">
        <div class="card-body p-3 p-md-4 lightbox-body">
          <div class="d-flex flex-wrap gap-2 justify-content-end mb-3">
            <button class="btn btn-outline-secondary btn-sm" @click="emit('prev')">
              <i class="bi bi-chevron-left"></i>
            </button>
            <button class="btn btn-primary btn-sm" @click="emit('togglePlay')">
              <i class="bi" :class="isPlaying ? 'bi-pause-fill' : 'bi-play-fill'"></i>
              {{ isPlaying ? 'Pausar' : 'Reproducir' }}
            </button>
            <button
              v-if="item?.type === 1"
              class="btn btn-outline-secondary btn-sm"
              @click="zoomOut"
            >
              <i class="bi bi-zoom-out"></i>
            </button>
            <button
              v-if="item?.type === 1"
              class="btn btn-outline-secondary btn-sm"
              @click="zoomIn"
            >
              <i class="bi bi-zoom-in"></i>
            </button>
            <button class="btn btn-outline-secondary btn-sm" @click="emit('next')">
              <i class="bi bi-chevron-right"></i>
            </button>
            <button class="btn btn-outline-danger btn-sm" @click="emit('close')">Cerrar</button>
          </div>

          <div
            class="viewer rounded"
            @pointerdown="handlePointerDown"
            @pointermove="handlePointerMove"
            @pointerup="handlePointerUp"
            @pointerleave="handlePointerUp"
            @dblclick="resetZoom"
          >
            <img
              v-if="item.type === 1"
              :src="item.url"
              :alt="item.title"
              class="zoom-media"
              :style="zoomStyle"
              draggable="false"
            />
            <video v-else :src="item.url" controls autoplay />
          </div>

          <h3 class="h5 mt-3 mb-1">{{ item.title }}</h3>
          <p class="text-secondary mb-2">{{ item.categoryName }} · {{ item.type === 1 ? 'Imagen' : 'Video' }}</p>
          <p v-if="item.description" class="text-secondary mb-0">{{ item.description }}</p>
        </div>
      </div>
    </div>
  </Transition>
</template>

