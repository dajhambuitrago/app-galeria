<script setup lang="ts">
import { computed, onBeforeUnmount, onMounted, ref } from 'vue'
import {
  addFavorite,
  getCategories,
  getFavorites,
  getMedia,
  getSlideshow,
  login,
  register,
  removeFavorite,
} from '@/services/api'
import type { CategoryDto, MediaDto, SlideshowDto } from '@/types/api'
import MediaLightbox from '@/components/MediaLightbox.vue'
import { useSlideshowPlayer } from '@/composables/useSlideshowPlayer'

type AuthMode = 'login' | 'register'

const authMode = ref<AuthMode>('login')
const email = ref('admin@appgaleria.local')
const password = ref('Admin123!')
const confirmPassword = ref('')
const token = ref(localStorage.getItem('appgaleria_token') ?? '')
const currentUserEmail = ref(localStorage.getItem('appgaleria_user_email') ?? '')
const selectedCategory = ref('')
const searchQuery = ref('')

const categories = ref<CategoryDto[]>([])
const mediaItems = ref<MediaDto[]>([])
const slideshow = ref<SlideshowDto | null>(null)
const error = ref('')
const loading = ref(false)
const favoriteIds = ref<Set<string>>(new Set())
const favoritesEnabled = ref(true)

const isAuthenticated = computed(() => !!token.value)
const slideshowDurationSeconds = computed(() => slideshow.value?.slideshowDurationSeconds ?? 8)
const isRegisterMode = computed(() => authMode.value === 'register')

const visibleItems = computed(() => {
  const q = searchQuery.value.trim().toLowerCase()
  if (!q) return mediaItems.value
  return mediaItems.value.filter(
    (x) => x.title.toLowerCase().includes(q) || x.categoryName.toLowerCase().includes(q),
  )
})

const {
  activeItem,
  isPlaying,
  openItem,
  openFirst,
  closeViewer,
  nextItem,
  prevItem,
  togglePlay,
  syncWithMediaItems,
  dispose,
} = useSlideshowPlayer(visibleItems, slideshowDurationSeconds)

function switchAuthMode(mode: AuthMode) {
  authMode.value = mode
  error.value = ''
  confirmPassword.value = ''
}

function selectCategory(name: string) {
  selectedCategory.value = name
  void loadMedia()
}

function startPresentation() {
  if (visibleItems.value.length === 0) return
  openFirst()
  if (!isPlaying.value) {
    togglePlay()
  }
}

async function handleAuthSubmit() {
  if (isRegisterMode.value) {
    await handleRegister()
    return
  }

  await handleLogin()
}

const favoritesStorageKey = computed(() =>
  currentUserEmail.value
    ? `appgaleria_favorites_${currentUserEmail.value.toLowerCase()}`
    : 'appgaleria_favorites',
)

function persistFavoritesToLocalStorage() {
  localStorage.setItem(favoritesStorageKey.value, JSON.stringify(Array.from(favoriteIds.value)))
}

function restoreFavoritesFromLocalStorage() {
  const raw = localStorage.getItem(favoritesStorageKey.value)
  if (!raw) {
    favoriteIds.value = new Set()
    return
  }

  try {
    const parsed = JSON.parse(raw) as string[]
    favoriteIds.value = new Set(parsed)
  } catch {
    favoriteIds.value = new Set()
  }
}

async function handleLogin() {
  try {
    loading.value = true
    error.value = ''
    const response = await login(email.value, password.value)
    token.value = response.token
    currentUserEmail.value = response.email
    localStorage.setItem('appgaleria_token', response.token)
    localStorage.setItem('appgaleria_user_email', response.email)
    await loadInitialData()
  } catch (e) {
    error.value = `No se pudo iniciar sesión: ${String(e)}`
  } finally {
    loading.value = false
  }
}

async function handleRegister() {
  if (password.value !== confirmPassword.value) {
    error.value = 'Las contraseñas no coinciden.'
    return
  }

  try {
    loading.value = true
    error.value = ''
    const response = await register(email.value, password.value)
    token.value = response.token
    currentUserEmail.value = response.email
    localStorage.setItem('appgaleria_token', response.token)
    localStorage.setItem('appgaleria_user_email', response.email)
    await loadInitialData()
  } catch (e) {
    error.value = `No se pudo registrar: ${String(e)}`
  } finally {
    loading.value = false
  }
}

function logout() {
  closeViewer()
  token.value = ''
  currentUserEmail.value = ''
  localStorage.removeItem('appgaleria_token')
  localStorage.removeItem('appgaleria_user_email')
  categories.value = []
  mediaItems.value = []
  slideshow.value = null
  searchQuery.value = ''
  favoriteIds.value = new Set()
  favoritesEnabled.value = true
}

function setFavoriteState(mediaId: string, value: boolean) {
  const next = new Set(favoriteIds.value)
  if (value) {
    next.add(mediaId)
  } else {
    next.delete(mediaId)
  }
  favoriteIds.value = next
  persistFavoritesToLocalStorage()
}

function isFavorite(mediaId: string) {
  return favoriteIds.value.has(mediaId)
}

async function toggleFavorite(mediaId: string) {
  if (!token.value || !favoritesEnabled.value) return

  const current = isFavorite(mediaId)
  setFavoriteState(mediaId, !current)

  try {
    if (current) {
      await removeFavorite(token.value, mediaId)
    } else {
      await addFavorite(token.value, mediaId)
    }
  } catch (e) {
    setFavoriteState(mediaId, current)
    error.value = `No se pudo actualizar favorito: ${String(e)}`
  }
}

async function loadFavorites() {
  if (!token.value) return

  restoreFavoritesFromLocalStorage()

  try {
    const favorites = await getFavorites(token.value)
    favoriteIds.value = new Set(favorites.map((x) => x.mediaItemId))
    favoritesEnabled.value = true
    persistFavoritesToLocalStorage()
  } catch {
    favoritesEnabled.value = false
  }
}

async function loadInitialData() {
  if (!token.value) return

  try {
    error.value = ''
    const [categoryData, slideshowData] = await Promise.all([
      getCategories(token.value),
      getSlideshow(token.value),
    ])

    categories.value = categoryData
    slideshow.value = slideshowData

    await Promise.all([loadMedia(), loadFavorites()])
  } catch (e) {
    error.value = `No se pudo cargar la galería: ${String(e)}`
    throw e
  }
}

async function loadMedia() {
  if (!token.value) return

  try {
    error.value = ''
    mediaItems.value = await getMedia(token.value, selectedCategory.value || undefined)
    syncWithMediaItems()
  } catch (e) {
    mediaItems.value = []
    error.value = `No se pudo cargar el contenido multimedia: ${String(e)}`
  }
}

onMounted(async () => {
  if (token.value) {
    try {
      await loadInitialData()
    } catch {
      logout()
    }
  }
})

onBeforeUnmount(() => {
  dispose()
})
</script>

<template>
  <main>
    <header class="hero">
      <div>
        <h1>appGaleria</h1>
        <p>Explora imágenes y videos por categorías.</p>
      </div>
      <button v-if="isAuthenticated" class="ghost-btn" @click="logout">Cerrar sesión</button>
    </header>

    <Transition name="fade-slide" mode="out-in">
      <section v-if="!isAuthenticated" key="login" class="login-shell">
        <div class="login-panel">
          <div class="auth-switch" role="tablist" aria-label="Modo de autenticación">
            <button
              class="auth-tab"
              :class="{ active: authMode === 'login' }"
              @click="switchAuthMode('login')"
            >
              Iniciar sesión
            </button>
            <button
              class="auth-tab"
              :class="{ active: authMode === 'register' }"
              @click="switchAuthMode('register')"
            >
              Registrarme
            </button>
          </div>

          <p class="login-kicker">Bienvenido</p>
          <h2>{{ isRegisterMode ? 'Crear cuenta' : 'Iniciar sesión' }}</h2>
          <p class="login-copy">
            {{
              isRegisterMode
                ? 'Regístrate para guardar tus favoritos y acceder a la galería.'
                : 'Accede para explorar la galería y usar el modo presentación.'
            }}
          </p>

          <form class="login-form" @submit.prevent="handleAuthSubmit">
            <label>
              Correo
              <input v-model="email" type="email" placeholder="tu-correo@ejemplo.com" required />
            </label>
            <label>
              Contraseña
              <input v-model="password" type="password" placeholder="••••••••" required />
            </label>
            <label v-if="isRegisterMode">
              Confirmar contraseña
              <input
                v-model="confirmPassword"
                type="password"
                placeholder="••••••••"
                required
              />
            </label>
            <button class="primary-btn" :disabled="loading" type="submit">
              {{
                loading
                  ? isRegisterMode
                    ? 'Registrando...'
                    : 'Ingresando...'
                  : isRegisterMode
                    ? 'Crear cuenta'
                    : 'Entrar'
              }}
            </button>
          </form>
        </div>
      </section>

      <section v-else key="gallery" class="card">
        <div class="toolbar">
          <div class="toolbar-title">
            <h2>Galería</h2>
            <span>{{ visibleItems.length }} elementos</span>
          </div>

          <div class="toolbar-actions">
            <input
              v-model="searchQuery"
              class="search"
              type="search"
              placeholder="Buscar por título o categoría"
            />
            <button class="primary-btn" :disabled="visibleItems.length === 0" @click="startPresentation">
              Iniciar presentación
            </button>
          </div>
        </div>

        <div class="chip-row">
          <button class="chip" :class="{ active: selectedCategory === '' }" @click="selectCategory('')">
            Todas
          </button>
          <button
            v-for="c in categories"
            :key="c.id"
            class="chip"
            :class="{ active: selectedCategory === c.name }"
            @click="selectCategory(c.name)"
          >
            {{ c.name }}
          </button>
        </div>

        <p v-if="slideshow" class="muted">
          Slideshow: {{ slideshow.slideshowDurationSeconds }}s · {{ slideshow.totalItems }} items ·
          {{ slideshow.effectiveOrder }}
        </p>

        <p v-if="visibleItems.length === 0" class="empty-state">
          No hay contenido multimedia que coincida con tu búsqueda.
        </p>

        <TransitionGroup name="card-fade" tag="div" class="grid">
          <article
            v-for="(item, index) in visibleItems"
            :key="item.id"
            class="item"
            @click="openItem(index)"
          >
            <div class="preview">
              <img v-if="item.type === 1" :src="item.url" :alt="item.title" loading="lazy" />
              <video v-else :src="item.url" controls preload="metadata" />
            </div>
            <div class="item-head">
              <h3>{{ item.title }}</h3>
              <button
                v-if="favoritesEnabled"
                class="fav-btn"
                :class="{ active: isFavorite(item.id) }"
                :aria-label="isFavorite(item.id) ? 'Quitar de favoritos' : 'Agregar a favoritos'"
                @click.stop="toggleFavorite(item.id)"
              >
                {{ isFavorite(item.id) ? '♥' : '♡' }}
              </button>
            </div>
            <p>{{ item.categoryName }} · {{ item.type === 1 ? 'Imagen' : 'Video' }}</p>
            <a :href="item.url" target="_blank" rel="noreferrer" @click.stop>Abrir</a>
          </article>
        </TransitionGroup>
      </section>
    </Transition>

    <Transition name="fade-slide">
      <p v-if="error" class="error">{{ error }}</p>
    </Transition>

    <MediaLightbox
      :item="activeItem"
      :is-playing="isPlaying"
      @close="closeViewer"
      @next="nextItem"
      @prev="prevItem"
      @toggle-play="togglePlay"
    />
  </main>
