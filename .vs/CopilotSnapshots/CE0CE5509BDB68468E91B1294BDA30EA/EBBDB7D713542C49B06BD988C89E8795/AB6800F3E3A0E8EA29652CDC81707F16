<script setup lang="ts">
import { computed, onBeforeUnmount, onMounted, ref } from 'vue'
import {
  addFavorite,
  createCategory,
  createMedia,
  deleteCategory,
  deleteMedia,
  getCategories,
  getFavorites,
  getMedia,
  getSlideshow,
  login,
  register,
  removeFavorite,
  updateCategory,
  updateMedia,
} from '@/services/api'
import type { CategoryDto, MediaDto, SlideshowDto } from '@/types/api'
import MediaLightbox from '@/components/MediaLightbox.vue'
import { useSlideshowPlayer } from '@/composables/useSlideshowPlayer'

type AuthMode = 'login' | 'register'
type ContentSection = 'all' | 'favorites'
type MediaLoadState = 'loading' | 'loaded' | 'error'

type AdminTab = 'media' | 'categories'

const authMode = ref<AuthMode>('login')
const contentSection = ref<ContentSection>('all')
const adminTab = ref<AdminTab>('media')
const email = ref('admin@appgaleria.local')
const password = ref('Admin123!')
const confirmPassword = ref('')
const token = ref(localStorage.getItem('appgaleria_token') ?? '')
const currentUserEmail = ref(localStorage.getItem('appgaleria_user_email') ?? '')
const currentUserRoles = ref<string[]>
  (JSON.parse(localStorage.getItem('appgaleria_user_roles') ?? '[]') as string[])
const selectedCategory = ref('')
const searchQuery = ref('')

const categories = ref<CategoryDto[]>([])
const mediaItems = ref<MediaDto[]>([])
const slideshow = ref<SlideshowDto | null>(null)
const error = ref('')
const loading = ref(false)
const favoriteIds = ref<Set<string>>(new Set())
const favoritesEnabled = ref(true)
const mediaLoadState = ref<Record<string, MediaLoadState>>({})
const apiBaseUrl = import.meta.env.VITE_API_BASE_URL ?? 'http://localhost:5241'

const newCategoryName = ref('')
const editingCategoryId = ref<string | null>(null)
const editingCategoryName = ref('')

const mediaForm = ref({
  id: '',
  title: '',
  url: '',
  type: 1,
  categoryId: '',
})

const isAuthenticated = computed(() => !!token.value)
const isAdmin = computed(() => currentUserRoles.value.includes('Admin'))
const slideshowDurationSeconds = computed(() => slideshow.value?.slideshowDurationSeconds ?? 8)
const isRegisterMode = computed(() => authMode.value === 'register')

const favoriteItems = computed(() => mediaItems.value.filter((x) => favoriteIds.value.has(x.id)))

const categoryMap = computed(() =>
  categories.value.reduce<Record<string, string>>((acc, category) => {
    acc[category.name] = category.id
    return acc
  }, {}),
)

const visibleItems = computed(() => {
  const source = contentSection.value === 'favorites' ? favoriteItems.value : mediaItems.value
  const q = searchQuery.value.trim().toLowerCase()
  if (!q) return source
  return source.filter(
    (x) => x.title.toLowerCase().includes(q) || x.categoryName.toLowerCase().includes(q),
  )
})

const {
  activeItem,
  isPlaying,
  openItem,
  openFirst,
  closeViewer,
  nextItem,
  prevItem,
  togglePlay,
  syncWithMediaItems,
  dispose,
} = useSlideshowPlayer(visibleItems, slideshowDurationSeconds)

function switchAuthMode(mode: AuthMode) {
  authMode.value = mode
  error.value = ''
  confirmPassword.value = ''
}

function switchContentSection(section: ContentSection) {
  contentSection.value = section
}

function switchAdminTab(tab: AdminTab) {
  adminTab.value = tab
}

function selectCategory(name: string) {
  selectedCategory.value = name
  void loadMedia()
}

function startPresentation() {
  if (visibleItems.value.length === 0) return
  openFirst()
  if (!isPlaying.value) {
    togglePlay()
  }
}

async function handleAuthSubmit() {
  if (isRegisterMode.value) {
    await handleRegister()
    return
  }

  await handleLogin()
}

const favoritesStorageKey = computed(() =>
  currentUserEmail.value
    ? `appgaleria_favorites_${currentUserEmail.value.toLowerCase()}`
    : 'appgaleria_favorites',
)

function persistFavoritesToLocalStorage() {
  localStorage.setItem(favoritesStorageKey.value, JSON.stringify(Array.from(favoriteIds.value)))
}

function restoreFavoritesFromLocalStorage() {
  const raw = localStorage.getItem(favoritesStorageKey.value)
  if (!raw) {
    favoriteIds.value = new Set()
    return
  }

  try {
    const parsed = JSON.parse(raw) as string[]
    favoriteIds.value = new Set(parsed)
  } catch {
    favoriteIds.value = new Set()
  }
}

function resolveMediaUrl(url: string) {
  return url.startsWith('http') ? url : `${apiBaseUrl}${url}`
}

async function handleLogin() {
  try {
    loading.value = true
    error.value = ''
    const response = await login(email.value, password.value)
    token.value = response.token
    currentUserEmail.value = response.email
    currentUserRoles.value = response.roles ?? []
    localStorage.setItem('appgaleria_token', response.token)
    localStorage.setItem('appgaleria_user_email', response.email)
    localStorage.setItem('appgaleria_user_roles', JSON.stringify(response.roles ?? []))
    await loadInitialData()
  } catch (e) {
    error.value = `No se pudo iniciar sesión: ${String(e)}`
  } finally {
    loading.value = false
  }
}

async function handleRegister() {
  if (password.value !== confirmPassword.value) {
    error.value = 'Las contraseñas no coinciden.'
    return
  }

  try {
    loading.value = true
    error.value = ''
    const response = await register(email.value, password.value)
    token.value = response.token
    currentUserEmail.value = response.email
    currentUserRoles.value = response.roles ?? []
    localStorage.setItem('appgaleria_token', response.token)
    localStorage.setItem('appgaleria_user_email', response.email)
    localStorage.setItem('appgaleria_user_roles', JSON.stringify(response.roles ?? []))
    await loadInitialData()
  } catch (e) {
    error.value = `No se pudo registrar: ${String(e)}`
  } finally {
    loading.value = false
  }
}

function logout() {
  closeViewer()
  token.value = ''
  currentUserEmail.value = ''
  currentUserRoles.value = []
  localStorage.removeItem('appgaleria_token')
  localStorage.removeItem('appgaleria_user_email')
  localStorage.removeItem('appgaleria_user_roles')
  categories.value = []
  mediaItems.value = []
  slideshow.value = null
  searchQuery.value = ''
  favoriteIds.value = new Set()
  favoritesEnabled.value = true
  contentSection.value = 'all'
  mediaLoadState.value = {}
}

function setFavoriteState(mediaId: string, value: boolean) {
  const next = new Set(favoriteIds.value)
  if (value) {
    next.add(mediaId)
  } else {
    next.delete(mediaId)
  }
  favoriteIds.value = next
  persistFavoritesToLocalStorage()
}

function isFavorite(mediaId: string) {
  return favoriteIds.value.has(mediaId)
}

function isMediaLoaded(mediaId: string) {
  return mediaLoadState.value[mediaId] === 'loaded'
}

function isMediaError(mediaId: string) {
  return mediaLoadState.value[mediaId] === 'error'
}

function markMediaState(mediaId: string, state: MediaLoadState) {
  mediaLoadState.value = { ...mediaLoadState.value, [mediaId]: state }
}

function resetMediaForm() {
  mediaForm.value = {
    id: '',
    title: '',
    url: '',
    type: 1,
    categoryId: categories.value[0]?.id ?? '',
  }
}

function selectMediaForEdit(item: MediaDto) {
  mediaForm.value = {
    id: item.id,
    title: item.title,
    url: item.url,
    type: item.type,
    categoryId: categoryMap.value[item.categoryName] ?? '',
  }
}

function openAdminMediaEditor(item: MediaDto) {
  adminTab.value = 'media'
  selectMediaForEdit(item)
}

async function saveMedia() {
  if (!token.value) return

  const payload = {
    title: mediaForm.value.title.trim(),
    url: mediaForm.value.url.trim(),
    type: Number(mediaForm.value.type),
    categoryId: mediaForm.value.categoryId,
    id: mediaForm.value.id,
  }

  if (!payload.title || !payload.url || !payload.categoryId) {
    error.value = 'Completa título, URL y categoría.'
    return
  }

  try {
    error.value = ''
    if (payload.id) {
      await updateMedia(token.value, payload)
    } else {
      await createMedia(token.value, payload)
    }

    resetMediaForm()
    await loadMedia()
  } catch (e) {
    error.value = `No se pudo guardar el media: ${String(e)}`
  }
}

async function removeMediaItem(id: string) {
  if (!token.value) return

  try {
    error.value = ''
    await deleteMedia(token.value, id)
    await loadMedia()
  } catch (e) {
    error.value = `No se pudo eliminar el media: ${String(e)}`
  }
}

function selectCategoryForEdit(category: CategoryDto) {
  editingCategoryId.value = category.id
  editingCategoryName.value = category.name
}

async function saveCategory() {
  if (!token.value) return

  const name = (editingCategoryId.value ? editingCategoryName.value : newCategoryName.value).trim()
  if (!name) {
    error.value = 'Ingresa el nombre de la categoría.'
    return
  }

  try {
    error.value = ''
    if (editingCategoryId.value) {
      await updateCategory(token.value, editingCategoryId.value, name)
    } else {
      await createCategory(token.value, name)
    }

    newCategoryName.value = ''
    editingCategoryId.value = null
    editingCategoryName.value = ''
    await loadCategories()
  } catch (e) {
    error.value = `No se pudo guardar la categoría: ${String(e)}`
  }
}

async function removeCategoryItem(id: string) {
  if (!token.value) return

  try {
    error.value = ''
    await deleteCategory(token.value, id)
    await loadCategories()
  } catch (e) {
    error.value = `No se pudo eliminar la categoría: ${String(e)}`
  }
}

async function toggleFavorite(mediaId: string) {
  if (!token.value || !favoritesEnabled.value) return

  const current = isFavorite(mediaId)
  setFavoriteState(mediaId, !current)

  try {
    if (current) {
      await removeFavorite(token.value, mediaId)
    } else {
      await addFavorite(token.value, mediaId)
    }
  } catch (e) {
    setFavoriteState(mediaId, current)
    error.value = `No se pudo actualizar favorito: ${String(e)}`
  }
}

async function loadFavorites() {
  if (!token.value) return

  restoreFavoritesFromLocalStorage()

  try {
    const favorites = await getFavorites(token.value)
    favoriteIds.value = new Set(favorites.map((x) => x.mediaItemId))
    favoritesEnabled.value = true
    persistFavoritesToLocalStorage()
  } catch {
    favoritesEnabled.value = false
  }
}

async function loadCategories() {
  if (!token.value) return

  categories.value = await getCategories(token.value)
  if (!mediaForm.value.categoryId && categories.value.length > 0) {
    mediaForm.value.categoryId = categories.value[0].id
  }
}

async function loadInitialData() {
  if (!token.value) return

  try {
    error.value = ''
    const [, slideshowData] = await Promise.all([loadCategories(), getSlideshow(token.value)])

    slideshow.value = slideshowData

    await Promise.all([loadMedia(), loadFavorites()])
  } catch (e) {
    error.value = `No se pudo cargar la galería: ${String(e)}`
    throw e
  }
}

async function loadMedia() {
  if (!token.value) return

  try {
    error.value = ''
    const data = await getMedia(token.value, selectedCategory.value || undefined)
    mediaItems.value = data.map((item) => ({
      ...item,
      url: resolveMediaUrl(item.url),
    }))
    mediaLoadState.value = Object.fromEntries(
      mediaItems.value.map((item) => [item.id, item.type === 1 ? 'loading' : 'loaded']),
    )
    syncWithMediaItems()
  } catch (e) {
    mediaItems.value = []
    error.value = `No se pudo cargar el contenido multimedia: ${String(e)}`
  }
}

function handleMediaLoad(mediaId: string) {
  markMediaState(mediaId, 'loaded')
}

function handleMediaError(mediaId: string) {
  markMediaState(mediaId, 'error')
}

function getCollageClass(index: number) {
  const pattern = index % 10

  if (pattern === 0 || pattern === 6) return 'tile-large'
  if (pattern === 3 || pattern === 8) return 'tile-tall'
  return 'tile-standard'
}

onMounted(async () => {
  if (token.value) {
    try {
      await loadInitialData()
    } catch {
      logout()
    }
  }
})

onBeforeUnmount(() => {
  dispose()
})
</script>

<template>
  <main class="container-fluid py-3 py-md-4 app-shell">
    <header class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-3 mb-md-4">
      <div>
        <h1 class="h3 mb-1 fw-bold">appGaleria</h1>
        <p class="text-secondary mb-0">Descubre contenido visual estilo Pinterest.</p>
      </div>
      <button v-if="isAuthenticated" class="btn btn-outline-secondary" @click="logout">
        <i class="bi bi-box-arrow-right me-1"></i>Cerrar sesión
      </button>
    </header>

    <Transition name="fade-slide" mode="out-in">
      <section v-if="!isAuthenticated" key="login" class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-5">
          <div class="card shadow-sm border-0 login-card">
            <div class="card-body p-4">
              <div class="btn-group w-100 mb-3" role="group" aria-label="Modo de autenticación">
                <button
                  type="button"
                  class="btn"
                  :class="authMode === 'login' ? 'btn-primary' : 'btn-outline-primary'"
                  @click="switchAuthMode('login')"
                >
                  Iniciar sesión
                </button>
                <button
                  type="button"
                  class="btn"
                  :class="authMode === 'register' ? 'btn-primary' : 'btn-outline-primary'"
                  @click="switchAuthMode('register')"
                >
                  Registrarme
                </button>
              </div>

              <h2 class="h4 mb-2">{{ isRegisterMode ? 'Crear cuenta' : 'Bienvenido de nuevo' }}</h2>
              <p class="text-secondary mb-3">
                {{
                  isRegisterMode
                    ? 'Regístrate para guardar tus favoritos y personalizar tu galería.'
                    : 'Accede para explorar, guardar favoritos y usar el modo presentación.'
                }}
              </p>

              <form class="d-grid gap-3" @submit.prevent="handleAuthSubmit">
                <div>
                  <label class="form-label">Correo</label>
                  <input v-model="email" class="form-control" type="email" placeholder="tu-correo@ejemplo.com" required />
                </div>
                <div>
                  <label class="form-label">Contraseña</label>
                  <input v-model="password" class="form-control" type="password" placeholder="••••••••" required />
                </div>
                <div v-if="isRegisterMode">
                  <label class="form-label">Confirmar contraseña</label>
                  <input v-model="confirmPassword" class="form-control" type="password" placeholder="••••••••" required />
                </div>

                <button class="btn btn-primary btn-lg" :disabled="loading" type="submit">
                  <span v-if="loading" class="spinner-border spinner-border-sm me-2" role="status"></span>
                  {{ loading ? (isRegisterMode ? 'Registrando...' : 'Ingresando...') : (isRegisterMode ? 'Crear cuenta' : 'Entrar') }}
                </button>
              </form>
            </div>
          </div>
        </div>
      </section>

      <section v-else key="gallery">
        <div class="card border-0 shadow-sm mb-3">
          <div class="card-body d-flex flex-column gap-3">
            <div class="d-flex flex-column flex-lg-row gap-3 justify-content-between align-items-lg-center">
              <div>
                <h2 class="h5 mb-1">{{ contentSection === 'favorites' ? 'Tus favoritos' : 'Galería' }}</h2>
                <small class="text-secondary">{{ visibleItems.length }} elementos visibles</small>
              </div>

              <div class="d-flex flex-column flex-md-row gap-2 w-100 w-lg-auto">
                <input
                  v-model="searchQuery"
                  class="form-control"
                  type="search"
                  placeholder="Buscar por título o categoría"
                />
                <button class="btn btn-primary" :disabled="visibleItems.length === 0" @click="startPresentation">
                  <i class="bi bi-play-circle me-1"></i>Iniciar presentación
                </button>
              </div>
            </div>

            <div class="btn-group" role="group" aria-label="Secciones">
              <button
                class="btn"
                :class="contentSection === 'all' ? 'btn-dark' : 'btn-outline-dark'"
                @click="switchContentSection('all')"
              >
                <i class="bi bi-grid me-1"></i>Galería
              </button>
              <button
                class="btn"
                :class="contentSection === 'favorites' ? 'btn-danger' : 'btn-outline-danger'"
                @click="switchContentSection('favorites')"
              >
                <i class="bi bi-heart-fill me-1"></i>Favoritos ({{ favoriteItems.length }})
              </button>
            </div>
          </div>
        </div>

        <div v-if="isAdmin" class="card border-0 shadow-sm mb-3">
          <div class="card-body">
            <div class="btn-group mb-3" role="group" aria-label="Admin">
              <button
                class="btn"
                :class="adminTab === 'media' ? 'btn-primary' : 'btn-outline-primary'"
                @click="switchAdminTab('media')"
              >
                <i class="bi bi-image me-1"></i>Media
              </button>
              <button
                class="btn"
                :class="adminTab === 'categories' ? 'btn-primary' : 'btn-outline-primary'"
                @click="switchAdminTab('categories')"
              >
                <i class="bi bi-tags me-1"></i>Categorías
              </button>
            </div>

            <div v-if="adminTab === 'media'" class="row g-3">
              <div class="col-12 col-lg-5">
                <h3 class="h6">{{ mediaForm.id ? 'Editar media' : 'Nuevo media' }}</h3>
                <div class="vstack gap-2">
                  <input v-model="mediaForm.title" class="form-control" placeholder="Título" />
                  <input v-model="mediaForm.url" class="form-control" placeholder="URL o ruta local (/media/...)" />
                  <select v-model="mediaForm.type" class="form-select">
                    <option :value="1">Imagen</option>
                    <option :value="2">Video</option>
                  </select>
                  <select v-model="mediaForm.categoryId" class="form-select">
                    <option disabled value="">Selecciona categoría</option>
                    <option v-for="cat in categories" :key="cat.id" :value="cat.id">{{ cat.name }}</option>
                  </select>
                  <div class="d-flex gap-2">
                    <button class="btn btn-success" @click="saveMedia">
                      {{ mediaForm.id ? 'Actualizar' : 'Guardar' }}
                    </button>
                    <button class="btn btn-outline-secondary" @click="resetMediaForm">Limpiar</button>
                  </div>
                </div>
              </div>

              <div class="col-12 col-lg-7">
                <h3 class="h6">Listado</h3>
                <div class="table-responsive">
                  <table class="table table-sm align-middle">
                    <thead>
                      <tr>
                        <th>Título</th>
                        <th>Categoría</th>
                        <th>Tipo</th>
                        <th></th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr v-for="item in mediaItems" :key="item.id">
                        <td class="text-truncate" style="max-width: 220px">{{ item.title }}</td>
                        <td>{{ item.categoryName }}</td>
                        <td>{{ item.type === 1 ? 'Imagen' : 'Video' }}</td>
                        <td class="text-end">
                          <button class="btn btn-sm btn-outline-primary me-2" @click="selectMediaForEdit(item)">
                            Editar
                          </button>
                          <button class="btn btn-sm btn-outline-danger" @click="removeMediaItem(item.id)">
                            Eliminar
                          </button>
                        </td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

            <div v-else class="row g-3">
              <div class="col-12 col-lg-5">
                <h3 class="h6">{{ editingCategoryId ? 'Editar categoría' : 'Nueva categoría' }}</h3>
                <div class="vstack gap-2">
                  <input
                    v-if="editingCategoryId"
                    v-model="editingCategoryName"
                    class="form-control"
                    placeholder="Nombre de la categoría"
                  />
                  <input
                    v-else
                    v-model="newCategoryName"
                    class="form-control"
                    placeholder="Nombre de la categoría"
                  />
                  <div class="d-flex gap-2">
                    <button class="btn btn-success" @click="saveCategory">
                      {{ editingCategoryId ? 'Actualizar' : 'Guardar' }}
                    </button>
                    <button
                      v-if="editingCategoryId"
                      class="btn btn-outline-secondary"
                      @click="() => { editingCategoryId = null; editingCategoryName = '' }"
                    >
                      Cancelar
                    </button>
                  </div>
                </div>
              </div>

              <div class="col-12 col-lg-7">
                <h3 class="h6">Listado</h3>
                <div class="table-responsive">
                  <table class="table table-sm align-middle">
                    <thead>
                      <tr>
                        <th>Nombre</th>
                        <th></th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr v-for="category in categories" :key="category.id">
                        <td>{{ category.name }}</td>
                        <td class="text-end">
                          <button class="btn btn-sm btn-outline-primary me-2" @click="selectCategoryForEdit(category)">
                            Editar
                          </button>
                          <button class="btn btn-sm btn-outline-danger" @click="removeCategoryItem(category.id)">
                            Eliminar
                          </button>
                        </td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="d-flex flex-wrap gap-2 mb-3 category-pills">
          <button
            class="btn btn-sm"
            :class="selectedCategory === '' ? 'btn-dark' : 'btn-outline-dark'"
            @click="selectCategory('')"
          >
            Todas
          </button>
          <button
            v-for="c in categories"
            :key="c.id"
            class="btn btn-sm"
            :class="selectedCategory === c.name ? 'btn-dark' : 'btn-outline-dark'"
            @click="selectCategory(c.name)"
          >
            {{ c.name }}
          </button>
        </div>

        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
          <span v-if="slideshow" class="badge text-bg-light border">
            <i class="bi bi-sliders me-1"></i>{{ slideshow.slideshowDurationSeconds }}s · {{ slideshow.totalItems }} · {{ slideshow.effectiveOrder }}
          </span>
          <span v-if="!favoritesEnabled" class="badge text-bg-warning">
            Favoritos habilitados solo para cuentas con rol User
          </span>
        </div>

        <p v-if="visibleItems.length === 0" class="text-secondary">
          {{ contentSection === 'favorites' ? 'Aún no tienes favoritos en esta vista.' : 'No hay contenido multimedia que coincida con tu búsqueda.' }}
        </p>

        <TransitionGroup name="card-fade" tag="div" class="collage-grid">
          <article
            v-for="(item, index) in visibleItems"
            :key="item.id"
            class="pin-card card border-0 shadow-sm"
            :class="getCollageClass(index)"
            @click="openItem(index)"
          >
            <div class="pin-media position-relative">
              <div v-if="item.type === 1" class="media-stage">
                <div v-if="!isMediaLoaded(item.id) && !isMediaError(item.id)" class="media-placeholder">
                  <div class="spinner-border text-light" role="status"></div>
                </div>

                <img
                  :src="item.url"
                  :alt="item.title"
                  loading="lazy"
                  decoding="async"
                  @load="handleMediaLoad(item.id)"
                  @error="handleMediaError(item.id)"
                />
              </div>

              <div v-else class="video-poster">
                <i class="bi bi-play-circle-fill"></i>
                <span>Video</span>
              </div>

              <div v-if="isMediaError(item.id)" class="media-error">
                <i class="bi bi-exclamation-triangle-fill me-1"></i>No se pudo cargar
              </div>

              <div v-if="isAdmin" class="admin-menu" @click.stop>
                <button class="btn btn-sm btn-light admin-menu-trigger" type="button">
                  <i class="bi bi-three-dots-vertical"></i>
                </button>
